<%= render "shared/partial" %>
<h3>予定一覧</h3>

<table>
  <thead>
    <tr>
      <th>id</th>
      <th>タイトル</th>
      <th>開始日</th>
      <th>終了日</th>
      <th>終日</th>
      <th>更新日時</th>
      <th></th>
      <th></th>
      <th></th>
    </tr>
  </thead>

  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.id %></td>
        <td><%= task.title %></td>
        <td><%= task.start_date&.strftime("%Y-%m-%d") %></td>
        <td><%= task.end_date&.strftime("%Y-%m-%d") %></td>
        <td><%= task.is_all_day %></td>
        <td><%= task.updated_at.strftime("%Y-%m-%d %H:%M") %></td>
        <td><%= link_to "詳細", task_path(task) %></td>
        <td><%= link_to "編集", edit_task_path(task) %></td>
        <td> <%= button_to "削除", task_path(task), method: :delete, data: { turbo_confirm: "本当に削除しますか?" } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<p><%= link_to "予定の新規登録", :new_task %></p>
